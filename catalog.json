    {
      "name": "Card",
      "import": "@corilus/kernel",
      "layer": "composite",
      "scope": "global",
      "status": "experimental",
      "summary": "Slot-driven base card for the Sprout pattern. Three fidelities (seed/sprout/shoot), two colour axes (tone/status), container-query intrinsic width morph.",
      "usecases": [
        "vital-sign",
        "lab-result",
        "demographic",
        "condition",
        "allergy",
        "medication",
        "sprout-pattern"
      ],
      "props": [
        {
          "name": "stage",
          "raw": "'seed'|'sprout'|'shoot'",
          "values": [
            "seed",
            "sprout",
            "shoot"
          ]
        },
        {
          "name": "tone",
          "raw": "'neutral'|'heart'|'breath'|'oxygen'|'temperature'|'pressure'|'body'|'lab'|'identity'|'condition'|'allergy'|'medication'",
          "values": [
            "neutral",
            "heart",
            "breath",
            "oxygen",
            "temperature",
            "pressure",
            "body",
            "lab",
            "identity",
            "condition",
            "allergy",
            "medication"
          ]
        },
        {
          "name": "customColor",
          "raw": "?string|{solid,tint,tintStrong,on}",
          "optional": true
        },
        {
          "name": "status",
          "raw": "?'normal'|'borderline'|'high'|'low'|'critical'",
          "optional": true,
          "values": [
            "normal",
            "borderline",
            "high",
            "low",
            "critical"
          ]
        },
        {
          "name": "loading",
          "raw": "?bool",
          "optional": true
        },
        {
          "name": "error",
          "raw": "?object",
          "optional": true
        },
        {
          "name": "empty",
          "raw": "?bool",
          "optional": true
        },
        {
          "name": "selected",
          "raw": "?bool",
          "optional": true
        },
        {
          "name": "disabled",
          "raw": "?bool",
          "optional": true
        },
        {
          "name": "stale",
          "raw": "?bool",
          "optional": true
        },
        {
          "name": "dragging",
          "raw": "?bool",
          "optional": true
        },
        {
          "name": "leading",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "title",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "trailing",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "value",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "meta",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "media",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "aside",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "footer",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "actions",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "ariaLabel",
          "raw": "?string",
          "optional": true
        },
        {
          "name": "role",
          "raw": "?string",
          "optional": true
        },
        {
          "name": "onClick",
          "raw": "?fn",
          "optional": true
        },
        {
          "name": "className",
          "raw": "?string",
          "optional": true
        }
      ],
      "composes": [],
      "usage": "<Card stage=\"sprout\" tone=\"heart\" title=\"Heart rate\" value={<ValueDisplay value=\"72\" unit=\"bpm\" />} />"
    },
