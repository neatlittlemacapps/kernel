      "props": [
        {
          "name": "initialStage",
          "raw": "'seed'|'sprout'|'shoot'",
          "values": [
            "seed",
            "sprout",
            "shoot"
          ]
        },
        {
          "name": "stage",
          "raw": "?'seed'|'sprout'|'shoot' (controlled mode)",
          "optional": true
        },
        {
          "name": "onStageChange",
          "raw": "?fn",
          "optional": true
        },
        {
          "name": "render",
          "raw": "fn"
        },
        {
          "name": "onRooted",
          "raw": "?fn",
          "optional": true
        },
        {
          "name": "className",
          "raw": "?string",
          "optional": true
        }
      ],
      "composes": [],
      "usage": "<SproutCard initialStage=\"seed\" render={(stage, t) => <VitalSignCard data={hr} stage={stage} onEdit={t.toShoot} />} />"
    },
