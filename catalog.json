{
  "standardVersion": "0.1.0",
  "components": [
    {
      "name": "ActionRow",
      "import": "@corilus/kernel",
      "layer": "atom",
      "scope": "global",
      "status": "stable",
      "summary": "The one canonical action/command row (icon · label · description · chevron); gating-aware.",
      "usecases": [
        "launcher",
        "slash-menu",
        "suggestion"
      ],
      "props": [
        {
          "name": "icon",
          "raw": "node"
        },
        {
          "name": "label",
          "raw": "string"
        },
        {
          "name": "description",
          "raw": "?string",
          "optional": true
        },
        {
          "name": "tone",
          "raw": "?string",
          "optional": true
        },
        {
          "name": "selected",
          "raw": "?bool",
          "optional": true
        },
        {
          "name": "disabled",
          "raw": "?bool",
          "optional": true
        },
        {
          "name": "reason",
          "raw": "?string",
          "optional": true
        },
        {
          "name": "onClick",
          "raw": "fn"
        }
      ],
      "composes": [],
      "usage": "<ActionRow icon={Icon.search({ size: 18 })} label=\"Search records\" description=\"Find a patient\" onClick={run} />"
    },
