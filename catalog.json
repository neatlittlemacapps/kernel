        "property-list",
        "dashboard",
        "sprout-pattern"
      ],
      "props": [
        {
          "name": "title",
          "raw": "?string",
          "optional": true
        },
        {
          "name": "items",
          "raw": "object[]"
        },
        {
          "name": "renderItem",
          "raw": "fn"
        },
        {
          "name": "layout",
          "raw": "'rows'|'grid'|'columns'",
          "values": [
            "rows",
            "grid",
            "columns"
          ]
        },
        {
          "name": "minCard",
          "raw": "?number",
          "optional": true
        },
        {
          "name": "density",
          "raw": "?'comfortable'|'compact'|'spacious'",
          "optional": true,
          "values": [
            "comfortable",
            "compact",
            "spacious"
          ]
        },
        {
          "name": "filter",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "sort",
          "raw": "?node",
          "optional": true
        },
        {
          "name": "action",
          "raw": "?node",
          "optional": true
        },
