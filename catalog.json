    {
      "name": "SproutCard",
      "import": "@corilus/kernel",
      "layer": "composite",
      "scope": "global",
      "status": "experimental",
      "summary": "Stateful wrapper that owns Seed↔Sprout↔Shoot stage state and applies the cross-stage view-transition animation. Render-prop based; per-object cards stay presentational.",
