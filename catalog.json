          "name": "emptyLabel",
          "raw": "?string",
          "optional": true
        },
        {
          "name": "ariaLabel",
          "raw": "?string",
          "optional": true
        },
        {
          "name": "className",
          "raw": "?string",
          "optional": true
        }
      ],
      "composes": [],
      "usage": "<PropertyList items={items} renderItem={(it) => <VitalSignCard data={it} stage=\"sprout\" />} layout=\"grid\" />"
