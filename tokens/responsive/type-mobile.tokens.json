{
  "type": {
    "size": {
      "$type": "dimension",
      "$description": "Type scale — MOBILE. Body holds at 16px (accessibility floor, prevents iOS zoom-on-focus); headings compress further for the narrow column. On mobile the density axis is pinned to one value (see CHANGELOG).",
      "2xs":  { "$value": { "value": 9,  "unit": "px" } },
      "xs":   { "$value": { "value": 11, "unit": "px" } },
      "sm":   { "$value": { "value": 13, "unit": "px" } },
      "base": { "$value": { "value": 16, "unit": "px" } },
      "lg":   { "$value": { "value": 18, "unit": "px" } },
      "xl":   { "$value": { "value": 20, "unit": "px" } },
      "2xl":  { "$value": { "value": 23, "unit": "px" } },
      "3xl":  { "$value": { "value": 27, "unit": "px" } },
      "4xl":  { "$value": { "value": 32, "unit": "px" } }
    }
  }
}
