    "tint": {
      "$description": "Brand-hue translucent overlays for the 'selected' state (must track the brand primary, unlike the hueless black/white interaction overlays which stay in primitives). soft = light theme, strong = dark theme. Concrete OKLCH-with-alpha at the Corilus primary hue (219.1) \u2014 an alpha move that composites over any surface, NOT a baked opaque shade. L/C taken from the former color.alpha.teal-12/-24 primitive (#0088a4) via hex_to_oklch, so Corilus stays pixel-identical to before; the hex fallback round-trips to #0088a4 exactly.",
      "soft": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.5792,
            0.1048,
            219.1
          ],
          "alpha": 0.12,
          "hex": "#0088a4"
        }
      },
      "strong": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.5792,
            0.1048,
            219.1
          ],
          "alpha": 0.24,
          "hex": "#0088a4"
        }
      }
    },
    "radius": {
      "$type": "dimension",
      "$description": "Brand corner character. The density modifier references these three steps (compact/base/spacious) instead of raw {radius.*}, so a brand shifts its whole roundness while density still varies one step around the base. Corilus = medium (12px) base.",
