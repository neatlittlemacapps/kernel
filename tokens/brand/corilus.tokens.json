{
  "brand": {
    "$type": "color",
    "$description": "Tier 2 brand identity \u2014 Corilus. This is the SINGLE chokepoint for everything that varies per brand: colour, radius, and font. The semantic, responsive and component tiers reference ONLY {brand.*} (and {font.*}/{brand.radius.*}) for those concerns \u2014 never a raw {color.*} ramp step. Swap the brand modifier to re-skin every interface. Hueless structural values (alpha overlays, scrim, shadow ink, transparent) stay in primitives \u2014 they are elevation/interaction physics, not brand identity.",
    "primary": {
      "$value": "{color.teal.600}",
      "$description": "Corilus teal. The action colour (default surfaces)."
    },
    "primary-deep": {
      "$value": "{color.teal.700}",
      "$description": "Deeper teal for solid fills that carry white text."
    },
    "primary-bright": {
      "$value": "{color.teal.400}",
      "$description": "Lighter teal for accents/icons on dark surfaces (AA on slate)."
    },
    "secondary": {
      "$value": "{color.mint.400}",
      "$description": "Corilus mint. Inverted surfaces + the console ambient indicator only."
    },
    "logo": {
      "$description": "Corilus Companion brain-mark gradient. Brand-FIXED identity colours (intentionally off-ramp) and theme-independent. The inline logo SVG fills its path with these via --brand-logo-from/--brand-logo-to. `angle` is the brand spec, baked into the SVG gradient geometry. Logos are exempt from WCAG text-contrast.",
      "from": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.7516,
            0.1426,
            225.17
          ],
          "hex": "#00c0f2"
        },
        "$description": "Gradient start \u2014 Corilus light blue (#00c0f2)."
      },
      "to": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.6645,
            0.1872,
            148.48
          ],
          "hex": "#0db14b"
        },
        "$description": "Gradient end \u2014 Corilus green (#0db14b)."
      },
      "angle": {
        "$type": "number",
        "$value": -52.3,
        "$description": "Brand gradient angle in degrees (CSS convention)."
      }
    },
    "ink": {
      "$description": "Content-ink scale \u2014 text, icons, chart ink. Corilus uses Graphite (near-zero chroma) so ink never tints adjacent data colours. A brand re-points this whole scale to its own neutral hue. Steps mirror the primitive ramp steps the design actually consumes.",
      "0": {
        "$value": "{color.graphite.0}"
      },
      "100": {
        "$value": "{color.graphite.100}"
      },
      "300": {
