          }
        }
      ]
    }
  },
  "inverted": {
    "$description": "In the dark theme the inverse block is LIGHT with dark text. Accent stays the brand accent hue (used as a fill with dark text).",
    "surface": {
      "$value": "{brand.neutral.paper}"
