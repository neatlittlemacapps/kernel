{
  "name": "@corilus/kernel",
  "version": "0.1.0",
  "private": true,
  "description": "Kernel - Corilus shippable design system: DTCG design tokens + Base UI component wrappers. Generic surface (.) + optional clinical tier (./clinical). Extracted from companion-forge/greenhouse.",
  "type": "module",
  "bin": {
    "kernel": "bin/kernel.mjs"
  },
  "exports": {
    ".": "./src/index.js",
    "./clinical": "./src/clinical.js",
    "./styles.css": "./src/styles.css",
    "./standard.json": "./standard.json",
    "./catalog.json": "./catalog.json",
    "./tokens/*": "./tokens/*"
  },
  "files": [
    "src",
    "tokens",
    "bin",
    "tools",
    "mcp",
    "templates",
    "standard.json",
    "catalog.json",
    "STANDARD.md",
    "CLI.md",
    "DOCS.md"
  ],
  "peerDependencies": {
    "@base-ui-components/react": "*",
    "react": "*",
    "react-dom": "*"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "catalog": "node tools/gen-catalog.mjs",
    "gate": "node tools/gen-catalog.mjs --check && node tools/catalog-gate.mjs src",
    "audit:greenhouse": "node tools/catalog-gate.mjs ../greenhouse/src --audit",
    "mcp": "node mcp/server.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@awesome.me/kit-c983fdf9da": "^1.0.5"
  }
}
