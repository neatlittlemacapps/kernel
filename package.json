{
  "name": "@corilus/kernel",
  "version": "0.1.0",
  "private": true,
  "description": "Kernel - Corilus shippable design system: DTCG design tokens + Base UI component wrappers. Generic surface (.) + optional clinical tier (./clinical). Extracted from companion-forge/greenhouse.",
  "type": "module",
  "bin": {
    "kernel": "bin/kernel.mjs"
  },
  "exports": {
    ".": "./src/index.js",
    "./clinical": "./src/clinical.js",
    "./chat": "./src/chat.js",
    "./styles.css": "./src/styles.css",
    "./standard.json": "./standard.json",
    "./catalog.json": "./catalog.json",
    "./tokens/*": "./tokens/*"
  },
  "files": [
    "src",
    "tokens",
    "bin",
    "tools",
    "mcp",
    "templates",
    "standard.json",
    "catalog.json",
    "STANDARD.md",
    "CLI.md",
    "DOCS.md"
  ],
  "peerDependencies": {
    "@base-ui-components/react": "*",
    "react": "*",
    "react-dom": "*"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "catalog": "node tools/gen-catalog.mjs",
    "gate": "node tools/gen-catalog.mjs --check && node tools/catalog-gate.mjs src",
    "audit:greenhouse": "node tools/catalog-gate.mjs ../greenhouse/src --audit",
    "mcp": "node mcp/server.mjs",
    "test": "node --test",
    "gen-stories": "node tools/gen-stories.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@awesome.me/kit-c983fdf9da": "^1.0.5"
  },
  "devDependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "playwright": "^1.61.1",
    "prop-types": "^15.8.1",
    "storybook": "^10.5.0",
    "vitest": "^4.1.10"
  }
}
